{
  "name": "@framevid/db",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push:pg",
    "db:migrate:sql": "echo Run: psql $DATABASE_URL -f drizzle/0000_init.sql"
  },
  "dependencies": {
    "@framevid/types": "workspace:*",
    "drizzle-orm": "^0.30.9",
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "drizzle-kit": "^0.20.17",
    "typescript": "^5.4.5"
  }
}
