# ==============================================================================
# FrameVid Environment Variables Template
# ==============================================================================

# Public API Settings
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_FRAMERVID_API_URL=http://localhost:3000/api/v1

# Local disk storage when Cloudflare R2 is not configured (dev uploads)
LOCAL_UPLOAD_DIR=./.data/uploads

# Custom Auth Configuration (Replacing Clerk)
JWT_SECRET=your_custom_jwt_secret_key_change_in_production
AUTH_COOKIE_NAME=framevid_session

# Database Configuration (PostgreSQL via Supabase or local Postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/framevid

# Redis Configuration (Upstash or local Redis for BullMQ)
REDIS_URL=redis://localhost:6379

# Storage Configuration (Cloudflare R2 bucket)
CLOUDFLARE_R2_ACCOUNT_ID=your_r2_account_id
CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
CLOUDFLARE_R2_BUCKET_NAME=framevid-assets
CLOUDFLARE_R2_PUBLIC_URL=https://cdn.framevid.co

# Analytics (ClickHouse event logging)
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# Optional Services (Skipped / Stubbed out by default)
# OPENAI_API_KEY=               # Whisper API (Skipped per user preference)
RESEND_API_KEY=your_resend_api_key
