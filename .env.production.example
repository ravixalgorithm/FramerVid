# =============================================================================
# FrameVid — Production environment variables
# Copy values into Vercel (dashboard) and Fly.io (worker) secrets dashboards.
# =============================================================================

# --- Vercel (apps/dashboard) ---
NEXT_PUBLIC_API_URL=https://your-app.vercel.app
NEXT_PUBLIC_FRAMERVID_API_URL=https://your-app.vercel.app/api/v1

JWT_SECRET=generate-a-random-string-at-least-32-characters-long
AUTH_COOKIE_NAME=framevid_session

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/framevid?sslmode=require
REDIS_URL=rediss://default:PASSWORD@HOST:6379

CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=framevid-assets
CLOUDFLARE_R2_PUBLIC_URL=https://cdn.framevid.co

# Optional later
# CLICKHOUSE_URL=
# RESEND_API_KEY=
# OPENAI_API_KEY=

# --- Fly.io worker (same DATABASE_URL, REDIS_URL, R2 vars) ---
# NODE_ENV=production
# Do NOT set LOCAL_UPLOAD_DIR in production.
