{
  "name": "framevid-monorepo",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "youtube-dl-exec",
      "msgpackr-extract",
      "esbuild",
      "es5-ext"
    ]
  },
  "scripts": {
    "build": "turbo run build",
    "railway:start": "pnpm --filter @framevid/db db:push && pnpm --filter @framevid/dashboard start",
    "railway:worker:start": "pnpm --filter @framevid/worker start",
    "railway:build": "pnpm build --filter=@framevid/dashboard --filter=@framevid/db --filter=@framevid/queue --filter=@framevid/types --filter=@framevid/worker",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "turbo": "^2.0.4",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  }
}
